{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python \"./host/start_codex_mobile_server.py\"",
            "commandWindows": "python \".\\host\\start_codex_mobile_server.py\"",
            "timeout": 5,
            "statusMessage": "Starting Codex LAN Monitor"
          },
          {
            "type": "command",
            "command": "python \"./host/codex_mobile_hook.py\"",
            "commandWindows": "python \".\\host\\codex_mobile_hook.py\"",
            "timeout": 5,
            "statusMessage": "Publishing Codex status"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"./host/codex_mobile_hook.py\"",
            "commandWindows": "python \".\\host\\codex_mobile_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"./host/codex_mobile_hook.py\"",
            "commandWindows": "python \".\\host\\codex_mobile_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"./host/codex_mobile_hook.py\"",
            "commandWindows": "python \".\\host\\codex_mobile_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"./host/codex_mobile_hook.py\"",
            "commandWindows": "python \".\\host\\codex_mobile_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"./host/codex_mobile_hook.py\"",
            "commandWindows": "python \".\\host\\codex_mobile_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
