# Optional. Prefer an OpenAI Admin key for organization usage/cost endpoints.
OPENAI_ADMIN_KEY=

# Optional fallback if your key has permission for usage/cost endpoints.
OPENAI_API_KEY=

# Optional, only needed when your account has multiple orgs/projects.
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# Optional. Used only for local budget warnings in this tool.
OPENAI_MONTHLY_BUDGET_USD=20

# Optional. Cache OpenAI cost/usage lookups to avoid querying on every phone refresh.
OPENAI_CACHE_SECONDS=300

# Optional but recommended on a shared LAN.
LOCAL_AGENT_TOKEN=change-this-local-token

# Server bind settings.
HOST=0.0.0.0
PORT=8787
